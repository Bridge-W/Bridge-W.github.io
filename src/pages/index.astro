---
import PageLayout from "@/layouts/PageLayout.astro";
import BlogCard from "@/components/content/BlogCard.astro";
import { getFeaturedPosts, getPublishedPosts } from "@/utils/content";
import { SITE } from "@/consts.ts";

const featuredPosts = await getFeaturedPosts(3);
const recentPosts = (await getPublishedPosts()).slice(0, 6);
---

<PageLayout title="首页">
	<!-- Hero 区域 -->
	<section class="py-20 px-4 text-center">
		<h1
			class="text-5xl font-bold mb-6 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent"
		>
			欢迎来到 {SITE.title}
		</h1>
		<p
			class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mb-8"
		>
			{SITE.description}
		</p>
		<div class="flex gap-4 justify-center">
			<a
				href="/blog"
				class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
			>
				阅读博客
			</a>
			<a
				href="/projects"
				class="px-6 py-3 border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
			>
				查看项目
			</a>
		</div>
	</section>

	<!-- 精选文章 -->
	{
		featuredPosts.length > 0 && (
			<section class="max-w-6xl mx-auto px-4 py-12">
				<h2 class="text-2xl font-bold mb-8">精选文章</h2>
				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
					{featuredPosts.map((post) => (
						<BlogCard post={post} />
					))}
				</div>
			</section>
		)
	}

	<!-- 最新文章 -->
	<section
		class="max-w-6xl mx-auto px-4 py-12 border-t border-gray-200 dark:border-gray-800"
	>
		<div class="flex justify-between items-center mb-8">
			<h2 class="text-2xl font-bold">最新文章</h2>
			<a href="/blog" class="text-blue-600 hover:underline">查看全部 →</a>
		</div>
		<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
			{recentPosts.map((post) => <BlogCard post={post} />)}
		</div>
	</section>
</PageLayout>
