---
// 这个组件不需要 props，完全自包含
---

<div
	id="email-toast"
	class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm opacity-0 transition-opacity duration-300"
>
	<div
		class="bg-white dark:bg-gray-900 rounded-2xl shadow-2xl p-6 max-w-sm w-full mx-4 transform scale-95 transition-transform duration-300 border border-gray-200 dark:border-gray-800"
	>
		<!-- 头部 -->
		<div class="flex items-center justify-between mb-4">
			<h3 class="text-lg font-bold text-gray-900 dark:text-gray-100">
				联系我
			</h3>
			<button
				id="close-toast"
				class="p-1 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-full transition-colors"
			>
				<svg
					class="w-5 h-5 text-gray-500"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M6 18L18 6M6 6l12 12"></path>
				</svg>
			</button>
		</div>

		<!-- 邮箱展示 -->
		<div class="bg-gray-50 dark:bg-gray-800/50 rounded-lg p-4 mb-4">
			<div class="flex items-center gap-3 mb-2">
				<div
					class="w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-full flex items-center justify-center"
				>
					<svg
						class="w-5 h-5 text-blue-600"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
						></path>
					</svg>
				</div>
				<div>
					<p class="text-sm text-gray-500 dark:text-gray-400">
						邮箱地址
					</p>
					<p
						id="email-display"
						class="font-sans text-sm text-gray-900 dark:text-gray-100 break-all"
					>
						wangqiao20211120@163.com
					</p>
				</div>
			</div>
		</div>

		<!-- 操作按钮 -->
		<div class="flex gap-3">
			<button
				id="copy-btn"
				class="flex-1 px-4 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition-colors flex items-center justify-center gap-2"
			>
				<svg
					class="w-4 h-4"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
					></path>
				</svg>
				<span id="copy-text">复制邮箱</span>
			</button>
		</div>
	</div>
</div>

<script>
	// 1. 扩展 Window 接口声明全局函数
	declare global {
		interface Window {
			showEmailToast: () => void;
		}
	}

	const toast = document.getElementById("email-toast") as HTMLDivElement;
	const closeBtn = document.getElementById(
		"close-toast",
	) as HTMLButtonElement;
	const copyBtn = document.getElementById("copy-btn") as HTMLButtonElement;
	const copyText = document.getElementById("copy-text") as HTMLSpanElement;
	const emailDisplay = document.getElementById(
		"email-display",
	) as HTMLParagraphElement;
	const email = emailDisplay.textContent ?? "";

	// 打开 Toast 的函数（暴露给全局）
	window.showEmailToast = function () {
		toast.classList.remove("hidden");
		// 强制重绘以触发过渡
		requestAnimationFrame(() => {
			toast.classList.add("flex");
			toast.classList.remove("opacity-0");
			// 现在需要选择内层的 flex 容器里的 div
			const innerDiv = toast.querySelector(
				".min-h-full > div",
			) as HTMLDivElement;
			innerDiv?.classList.remove("scale-95");
			innerDiv?.classList.add("scale-100");
		});
	};

	// 关闭 Toast
	function closeToast(): void {
		toast.classList.add("opacity-0");
		const innerDiv = toast.querySelector(
			".min-h-full > div",
		) as HTMLDivElement;
		innerDiv?.classList.remove("scale-100");
		innerDiv?.classList.add("scale-95");
		setTimeout(() => {
			toast.classList.add("hidden");
		}, 300);
	}

	closeBtn?.addEventListener("click", closeToast);

	// 点击背景关闭
	toast?.addEventListener("click", (e) => {
		if (e.target === toast) closeToast();
	});

	// 复制功能
	copyBtn?.addEventListener("click", async () => {
		try {
			await navigator.clipboard.writeText(email);
			copyText.textContent = "已复制！";
			copyBtn.classList.add("bg-green-600", "hover:bg-green-700");
			copyBtn.classList.remove("bg-blue-600", "hover:bg-blue-700");

			setTimeout(() => {
				copyText.textContent = "复制邮箱";
				copyBtn.classList.remove("bg-green-600", "hover:bg-green-700");
				copyBtn.classList.add("bg-blue-600", "hover:bg-blue-700");
			}, 2000);
		} catch (err) {
			// 降级方案
			const input = document.createElement("input");
			input.value = email;
			document.body.appendChild(input);
			input.select();
			document.execCommand("copy");
			document.body.removeChild(input);

			copyText.textContent = "已复制！";
			setTimeout(() => {
				copyText.textContent = "复制邮箱";
			}, 2000);
		}
	});

	// ESC 键关闭
	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape" && !toast.classList.contains("hidden")) {
			closeToast();
		}
	});
</script>
