---
interface Props {
    tags: string[];
}

const { tags } = Astro.props;
---

<div class="flex flex-wrap gap-2">
    {
        tags.map((tag) => (
            <a
                href={`/blog/tags/${tag}/`}
                class="text-sm px-3 py-1 bg-gray-100 dark:bg-gray-800 hover:bg-blue-100 dark:hover:bg-blue-900/30 rounded-full transition-colors"
            >
                {tag}
            </a>
        ))
    }
</div>
