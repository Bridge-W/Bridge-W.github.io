---
import PageLayout from "@/layouts/PageLayout.astro";
import BlogCard from "@/components/content/BlogCard.astro";
import { getPublishedPosts, getAllTags } from "@/utils/content";
import { PAGINATION } from "@/consts";

const posts = await getPublishedPosts();
const tags = await getAllTags();
---

<PageLayout title="博客">
	<div class="max-w-6xl mx-auto px-4 py-12">
		<h1 class="text-4xl font-bold mb-8">博客文章</h1>

		<!-- 标签云 -->
		<div class="mb-12">
			<h2 class="text-sm font-bold text-gray-500 uppercase mb-4">
				热门标签
			</h2>
			<div class="flex flex-wrap gap-2">
				{
					tags.slice(0, 10).map(({ name, count }) => (
						<a
							href={`/blog/tags/${name}/`}
							class="px-3 py-1 bg-gray-100 dark:bg-gray-800 rounded-full text-sm hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors"
						>
							{name} ({count})
						</a>
					))
				}
			</div>
		</div>

		<!-- 文章网格 -->
		<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
			{posts.map((post) => <BlogCard post={post} />)}
		</div>

		<!-- 分页（简化版，可扩展） -->
		{
			posts.length > PAGINATION.postsPerPage && (
				<div class="mt-12 text-center">
					<p class="text-gray-600 dark:text-gray-400">
						显示 {posts.length} 篇文章
					</p>
				</div>
			)
		}
	</div>
</PageLayout>
