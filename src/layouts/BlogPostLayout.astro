---
import BaseLayout from "./BaseLayout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import TableOfContents from "@/components/content/TableOfContents.astro";
import TagList from "@/components/content/TagList.astro";
import { formatDate } from "@/utils/formatDate";
import type { CollectionEntry } from "astro:content";

// 支持两种方式传参：
// 1. 博客文章：传入 frontmatter + headings + readingTime
// 2. 普通页面：直接传入 title + description + pubDate 等

interface BlogProps {
    frontmatter: CollectionEntry<"blog">["data"];
    headings: { depth: number; slug: string; text: string }[];
    readingTime: number;
}

interface PageProps {
    title: string;
    description: string;
    pubDate?: Date;
    updatedDate?: Date;
    tags?: string[];
    coverImage?: string;
    author?: string;
    headings?: { depth: number; slug: string; text: string }[];
    readingTime?: number;
}

type Props = BlogProps | PageProps;

const props = Astro.props;

// 判断是哪种模式
const isBlogMode = "frontmatter" in props;

// 统一提取数据
const title = isBlogMode ? props.frontmatter.title : props.title;
const description = isBlogMode
    ? props.frontmatter.description
    : props.description;
const pubDate = isBlogMode
    ? props.frontmatter.pubDate
    : props.pubDate || new Date();
const updatedDate = isBlogMode
    ? props.frontmatter.updatedDate
    : props.updatedDate;
const tags = isBlogMode ? props.frontmatter.tags : props.tags || [];
const coverImage = isBlogMode ? props.frontmatter.coverImage : props.coverImage;
const author = isBlogMode
    ? props.frontmatter.author
    : props.author || "default";
const headings = isBlogMode ? props.headings : props.headings || [];
const readingTime = isBlogMode ? props.readingTime : props.readingTime || 1;
---

<BaseLayout
    title={title}
    description={description}
    image={coverImage}
    type="article"
>
    <Header />

    <article class="max-w-4xl mx-auto px-4 py-12">
        <header class="mb-8">
            {
                coverImage && (
                    <img
                        src={coverImage}
                        alt={title}
                        class="w-full h-64 object-cover rounded-lg mb-6"
                    />
                )
            }

            <h1 class="text-4xl font-bold mb-4">{title}</h1>

            <div
                class="flex flex-wrap items-center gap-4 text-gray-600 dark:text-gray-400 text-sm"
            >
                <time datetime={pubDate.toISOString()}>
                    {formatDate(pubDate)}
                </time>
                {updatedDate && <span>更新于 {formatDate(updatedDate)}</span>}
                <span>·</span>
                <span>{readingTime} 分钟阅读</span>
                <span>·</span>
                <span>{author}</span>
            </div>

            {
                tags.length > 0 && (
                    <div class="mt-4">
                        <TagList tags={tags} />
                    </div>
                )
            }
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
            {
                headings.length > 0 && (
                    <aside class="hidden lg:block lg:col-span-1">
                        <div class="sticky top-24">
                            <TableOfContents headings={headings} />
                        </div>
                    </aside>
                )
            }

            <div
                class:list={[
                    "prose dark:prose-invert max-w-none",
                    headings.length > 0 ? "lg:col-span-3" : "lg:col-span-4",
                ]}
            >
                <slot />
            </div>
        </div>
    </article>

    <Footer />
</BaseLayout>
